{
  "mcpServers": {
    "jira": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-jira-cloud"
      ],
      "env": {}
    },
    "github": {
      "command": "gh",
      "args": [
        "mcp"
      ]
    },
    "bigquery": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@ergut/mcp-bigquery-server",
        "--project-id",
        "dw-main-silver",
        "--location",
        "US"
      ],
      "env": {}
    }
  }
}